### DYNAMIC PARAMETERS ###

# User configuration
ROS_DOMAIN_ID=0
HOST_UID=1000
HOST_GID=1000

# Build parameters - NEW: ROS_DISTRO as configurable parameter
ROS_DISTRO=galactic
RMW_IMPLEMENTATION=rmw_cyclonedds_cpp
PIP_BREAK_SYSTEM_PACKAGES=1

### STATIC PARAMETERS ###

# Tracing Parameters
ROS_TRACE_DIR=/home/ubuntu/workspace/traces
LTTNG_HOME=/var/run/lttng

# Package names for services
# Space-separated list of package names to build (now supports nested packages)

# Extra packages (system packages to install)
DEMO_PACKAGES=ros-${ROS_DISTRO}-demo-nodes-cpp
TF2_TOOLS_PACKAGES=ros-${ROS_DISTRO}-tf2-tools
RQT_PACKAGES=ros-${ROS_DISTRO}-rqt*

